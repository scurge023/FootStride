<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FootStride — Built for the Road</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Anton&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
<style>
  :root{
    --charcoal:#1a1a18;
    --charcoal-soft:#26241f;
    --cream:#f5f2ea;
    --cream-dim:#e8e3d6;
    --stone:#b8b2a3;
    --orange:#c2562f;
    --orange-dim:#a3461f;
    --green:#4f6b57;
    --sage:#7c8a6e;
    --rose:#b08576;
    --radius:2px;
    --maxw:1280px;
  }
  *{box-sizing:border-box; margin:0; padding:0;}
  html{scroll-behavior:smooth;}
  body{
    background:var(--cream);
    color:var(--charcoal);
    font-family:'Inter',sans-serif;
    -webkit-font-smoothing:antialiased;
    overflow-x:hidden;
  }
  ::selection{background:var(--orange); color:var(--cream);}
  a{color:inherit; text-decoration:none;}
  img{display:block; max-width:100%;}
  .wrap{max-width:var(--maxw); margin:0 auto; padding:0 32px;}
  .mono{font-family:'JetBrains Mono',monospace;}
  .display{font-family:'Anton',sans-serif; font-weight:400; letter-spacing:0.01em; text-transform:uppercase;}

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce){
    *{animation-duration:0.001ms !important; animation-iteration-count:1 !important; transition-duration:0.001ms !important; scroll-behavior:auto !important;}
  }

  /* ---------- Focus ---------- */
  a:focus-visible, button:focus-visible, input:focus-visible{
    outline:2px solid var(--orange);
    outline-offset:3px;
  }

  /* ---------- Topbar ---------- */
  .topbar{
    background:var(--charcoal);
    color:var(--stone);
    font-family:'JetBrains Mono',monospace;
    font-size:11px;
    letter-spacing:0.08em;
    text-transform:uppercase;
    padding:8px 0;
  }
  .topbar .wrap{display:flex; justify-content:center; align-items:center;}
  .topbar span{color:var(--orange);}

  /* ---------- Header ---------- */
  header{
    position:sticky; top:0; z-index:100;
    background:rgba(245,242,234,0.92);
    backdrop-filter:blur(10px);
    border-bottom:1px solid rgba(26,26,24,0.1);
    transition:border-color .3s ease;
  }
  .nav{
    display:flex; align-items:center; justify-content:space-between;
    padding:20px 32px;
    max-width:var(--maxw); margin:0 auto;
  }
  .logo{
    font-family:'Anton',sans-serif;
    font-size:26px;
    letter-spacing:0.01em;
    display:flex; align-items:center; gap:10px;
  }
  .logo .dot{width:9px; height:9px; background:var(--orange); border-radius:50%; display:inline-block;}
  .navlinks{display:flex; gap:36px; font-size:14px; font-weight:600;}
  .navlinks a{position:relative; padding:4px 0; transition:color .2s ease;}
  .navlinks a::after{
    content:''; position:absolute; left:0; bottom:0; width:0; height:2px; background:var(--orange);
    transition:width .25s ease;
  }
  .navlinks a:hover::after{width:100%;}
  .navlinks a:hover{color:var(--orange-dim);}
  .navactions{display:flex; align-items:center; gap:22px;}
  .icon-btn{
    background:none; border:none; cursor:pointer; position:relative;
    display:flex; align-items:center; justify-content:center;
    width:38px; height:38px; color:var(--charcoal);
    transition:transform .2s ease;
  }
  .icon-btn:hover{transform:translateY(-2px); color:var(--orange-dim);}
  .icon-btn svg{width:20px; height:20px;}
  .cart-count{
    position:absolute; top:0; right:0;
    background:var(--orange); color:var(--cream);
    font-family:'JetBrains Mono',monospace; font-size:10px; font-weight:700;
    width:16px; height:16px; border-radius:50%;
    display:flex; align-items:center; justify-content:center;
  }
  .menu-toggle{
    display:flex; align-items:center; justify-content:center;
    width:38px; height:38px; background:none; border:none; cursor:pointer;
    color:var(--charcoal); transition:transform .2s ease, color .2s ease;
  }
  .menu-toggle:hover{color:var(--orange-dim); transform:translateY(-2px);}
  .menu-toggle svg{width:21px; height:21px;}
  .nav-left{display:flex; align-items:center; gap:18px;}

  /* ---------- Hero ---------- */
  .hero{
    position:relative;
    padding:46px 32px 0;
    max-width:var(--maxw); margin:0 auto;
    display:grid; grid-template-columns:1.05fr 0.95fr; align-items:center; gap:40px;
    min-height:62vh;
  }
  .hero-eyebrow{
    font-family:'JetBrains Mono',monospace; font-size:12px; letter-spacing:0.18em;
    text-transform:uppercase; color:var(--orange-dim); margin-bottom:22px;
    display:flex; align-items:center; gap:10px;
    opacity:0; animation:fadeUp .7s ease forwards;
  }
  .hero-eyebrow::before{content:''; width:28px; height:1px; background:var(--orange-dim);}
  .hero h1{
    font-size:clamp(48px,7vw,92px);
    line-height:0.92;
    margin-bottom:26px;
    opacity:0; animation:fadeUp .8s ease .1s forwards;
  }
  .hero h1 .stroke{
    -webkit-text-stroke:1.5px var(--charcoal);
    color:transparent;
  }
  .hero p{
    font-size:17px; line-height:1.6; color:#4a4742; max-width:440px; margin-bottom:36px;
    opacity:0; animation:fadeUp .8s ease .2s forwards;
  }
  .hero-ctas{display:flex; gap:16px; align-items:center; opacity:0; animation:fadeUp .8s ease .3s forwards;}
  .btn{
    display:inline-flex; align-items:center; gap:10px;
    padding:16px 30px;
    font-family:'Inter',sans-serif; font-weight:700; font-size:14px;
    letter-spacing:0.02em; text-transform:uppercase;
    border-radius:var(--radius); cursor:pointer; border:1.5px solid transparent;
    transition:all .25s cubic-bezier(.2,.7,.3,1);
  }
  .btn-primary{background:var(--charcoal); color:var(--cream);}
  .btn-primary:hover{background:var(--orange); transform:translateY(-3px); box-shadow:0 10px 24px -8px rgba(255,90,31,0.55);}
  .btn-ghost{border-color:var(--charcoal); color:var(--charcoal);}
  .btn-ghost:hover{border-color:var(--orange-dim); color:var(--orange-dim); transform:translateY(-3px);}

  .hero-stats{display:flex; gap:34px; margin-top:32px; opacity:0; animation:fadeUp .8s ease .4s forwards;}
  .hero-stats div{border-left:2px solid var(--charcoal); padding-left:14px;}
  .hero-stats .num{font-family:'Anton',sans-serif; font-size:26px;}
  .hero-stats .label{font-family:'JetBrains Mono',monospace; font-size:10.5px; color:#6b675e; text-transform:uppercase; letter-spacing:.06em;}

  .hero-art{
    position:relative; height:440px;
    display:flex; align-items:center; justify-content:center;
  }
  .hero-art .ring{
    position:absolute; width:430px; height:430px; border-radius:50%;
    border:1px dashed rgba(26,26,24,0.18);
    animation:spin 40s linear infinite;
  }
  .hero-art .ring2{width:340px; height:340px; border-color:rgba(124,138,110,0.35); animation-direction:reverse; animation-duration:30s;}
  .hero-art img{
    width:520px; max-width:120%; transform:rotate(-18deg);
    filter:drop-shadow(0 40px 50px rgba(26,26,24,0.28));
    animation:float 5s ease-in-out infinite, fadeUp 1s ease .3s backwards;
  }
  .hero-tag{
    position:absolute; bottom:18px; left:0;
    background:var(--charcoal); color:var(--cream);
    font-family:'JetBrains Mono',monospace; font-size:11px;
    padding:10px 14px; display:flex; gap:10px; align-items:center;
    border-radius:var(--radius);
  }
  .hero-tag .swatch{width:9px; height:9px; background:var(--orange); border-radius:50%;}

  @keyframes fadeUp{from{opacity:0; transform:translateY(22px);} to{opacity:1; transform:translateY(0);}}
  @keyframes float{0%,100%{transform:rotate(-18deg) translateY(0);} 50%{transform:rotate(-15deg) translateY(-16px);}}
  @keyframes spin{to{transform:rotate(360deg);}}

  /* ---------- Marquee ---------- */
  .marquee{
    background:var(--charcoal); color:var(--stone);
    overflow:hidden; white-space:nowrap; padding:14px 0; margin-top:40px;
    border-top:1px solid rgba(245,242,234,0.08); border-bottom:1px solid rgba(245,242,234,0.08);
  }
  .marquee-track{display:inline-flex; gap:48px; animation:scroll 28s linear infinite;}
  .marquee span{
    font-family:'Anton',sans-serif; font-size:15px; letter-spacing:0.04em; text-transform:uppercase;
    display:inline-flex; align-items:center; gap:48px;
  }
  .marquee span em{font-style:normal; color:var(--rose); margin:0 0 0 -34px;}
  @keyframes scroll{from{transform:translateX(0);} to{transform:translateX(-50%);}}

  /* ---------- Section heading ---------- */
  .section{padding:70px 0;}
  .section-head{
    display:flex; justify-content:space-between; align-items:flex-end;
    margin-bottom:56px; gap:24px; flex-wrap:wrap;
  }
  .section-head .eyebrow{
    font-family:'JetBrains Mono',monospace; font-size:12px; color:var(--orange-dim);
    letter-spacing:0.14em; text-transform:uppercase; margin-bottom:14px; display:block;
  }
  .section-head h2{font-size:clamp(32px,4vw,48px); line-height:1;}
  .section-head p{max-width:380px; color:#5c584f; font-size:15px; line-height:1.6;}

  /* ---------- Filters ---------- */
  .filters{display:flex; gap:10px; margin-bottom:44px; flex-wrap:wrap;}
  .chip{
    font-family:'JetBrains Mono',monospace; font-size:12px; letter-spacing:.04em;
    text-transform:uppercase; padding:9px 18px; border:1px solid rgba(26,26,24,0.22);
    border-radius:30px; cursor:pointer; background:transparent; color:var(--charcoal);
    transition:all .2s ease;
  }
  .chip:hover{border-color:var(--charcoal);}
  .chip.active{background:var(--charcoal); color:var(--cream); border-color:var(--charcoal);}

  /* ---------- Product grid ---------- */
  .grid{
    display:grid; grid-template-columns:repeat(4,1fr); gap:28px;
  }
  .card{
    background:var(--cream-dim);
    border-radius:var(--radius);
    overflow:hidden;
    position:relative;
    transition:transform .35s cubic-bezier(.2,.7,.3,1), box-shadow .35s ease;
    opacity:0; transform:translateY(24px);
  }
  .card.in-view{animation:fadeUp .6s ease forwards;}
  .card:hover{transform:translateY(-8px); box-shadow:0 24px 40px -20px rgba(26,26,24,0.35);}
  .card-media{
    position:relative; aspect-ratio:1/1; overflow:hidden;
    background:linear-gradient(160deg,#ece7da,#dcd6c5);
  }
  .card-media img{
    width:100%; height:100%; object-fit:cover;
    transition:transform .6s cubic-bezier(.2,.7,.3,1);
  }
  .card:hover .card-media img{transform:scale(1.08) rotate(-2deg);}
  .badge{
    position:absolute; top:12px; left:12px;
    font-family:'JetBrains Mono',monospace; font-size:10px; text-transform:uppercase;
    letter-spacing:.05em; padding:6px 10px; border-radius:30px;
    background:var(--orange); color:var(--cream);
  }
  .badge.green{background:var(--green);}
  .badge.sage{background:var(--sage);}
  .quick-add{
    position:absolute; right:12px; bottom:12px;
    width:42px; height:42px; border-radius:50%;
    background:var(--charcoal); color:var(--cream);
    display:flex; align-items:center; justify-content:center;
    border:none; cursor:pointer;
    transform:translateY(60px); opacity:0;
    transition:all .3s cubic-bezier(.2,.7,.3,1);
  }
  .card:hover .quick-add{transform:translateY(0); opacity:1;}
  .quick-add:hover{background:var(--orange);}
  .quick-add svg{width:18px; height:18px;}
  .card-info{padding:18px 18px 22px;}
  .card-info .cat{
    font-family:'JetBrains Mono',monospace; font-size:10.5px; color:#7a766b;
    text-transform:uppercase; letter-spacing:.06em; margin-bottom:6px; display:block;
  }
  .card-info h3{font-size:16.5px; font-weight:600; margin-bottom:10px; line-height:1.3;}
  .card-foot{display:flex; justify-content:space-between; align-items:center;}
  .price{font-family:'JetBrains Mono',monospace; font-weight:700; font-size:15px;}
  .price .was{color:#9a958a; text-decoration:line-through; font-weight:400; margin-right:6px; font-size:13px;}
  .swatches{display:flex; gap:5px;}
  .swatches i{width:11px; height:11px; border-radius:50%; display:inline-block; border:1px solid rgba(26,26,24,.15);}

  /* ---------- Ratings strip ---------- */
  .ratings-strip{
    background:var(--charcoal-soft); color:var(--cream);
    padding:46px 0; margin-top:6px;
  }
  .ratings-strip .wrap{
    display:flex; align-items:center; justify-content:space-between; gap:32px; flex-wrap:wrap;
  }
  .ratings-score{display:flex; align-items:center; gap:18px;}
  .ratings-score .num{font-family:'Anton',sans-serif; font-size:44px; line-height:1;}
  .ratings-stars{color:var(--orange); font-size:15px; letter-spacing:2px; margin-bottom:4px;}
  .ratings-score .label{font-family:'JetBrains Mono',monospace; font-size:11.5px; color:var(--stone); text-transform:uppercase; letter-spacing:.06em;}
  .ratings-quote{
    font-size:14.5px; color:var(--stone); max-width:420px; line-height:1.6; border-left:2px solid var(--orange); padding-left:18px;
  }
  .ratings-quote span{color:var(--cream); font-weight:600;}

  /* ---------- Footer ---------- */
  footer{background:var(--charcoal); color:var(--stone); padding:70px 0 28px;}
  .foot-grid{display:grid; grid-template-columns:1.4fr 1fr 1fr; gap:40px; padding-bottom:50px; border-bottom:1px solid rgba(245,242,234,0.1);}
  .foot-logo{font-family:'Anton',sans-serif; font-size:24px; color:var(--cream); margin-bottom:14px;}
  .foot-grid p{font-size:13.5px; line-height:1.7; max-width:280px;}
  .foot-col h5{font-family:'JetBrains Mono',monospace; font-size:11px; text-transform:uppercase; letter-spacing:.08em; color:var(--cream); margin-bottom:18px;}
  .foot-col a{display:block; font-size:14px; margin-bottom:11px; color:var(--stone); transition:color .2s ease;}
  .foot-col a:hover{color:var(--orange);}
  .foot-bottom{display:flex; justify-content:space-between; align-items:center; padding-top:24px; font-size:12.5px; font-family:'JetBrains Mono',monospace; color:#7a766b; flex-wrap:wrap; gap:14px;}

  /* ---------- Cart drawer ---------- */
  .overlay{
    position:fixed; inset:0; background:rgba(26,26,24,0.45);
    opacity:0; pointer-events:none; transition:opacity .35s ease; z-index:200;
  }
  .overlay.open{opacity:1; pointer-events:all;}
  .drawer{
    position:fixed; top:0; right:0; bottom:0; width:420px; max-width:92vw;
    background:var(--cream); z-index:201;
    transform:translateX(100%); transition:transform .4s cubic-bezier(.2,.7,.3,1);
    display:flex; flex-direction:column;
  }
  .drawer.open{transform:translateX(0);}
  .drawer-head{display:flex; justify-content:space-between; align-items:center; padding:26px 28px; border-bottom:1px solid rgba(26,26,24,0.1);}
  .drawer-head h3{font-family:'Anton',sans-serif; font-size:20px;}
  .drawer-close{background:none; border:none; cursor:pointer; width:34px; height:34px; display:flex; align-items:center; justify-content:center;}
  .drawer-close svg{width:18px; height:18px;}
  .drawer-body{flex:1; overflow-y:auto; padding:10px 28px;}
  .drawer-empty{display:flex; flex-direction:column; align-items:center; justify-content:center; height:100%; text-align:center; color:#7a766b; gap:14px;}
  .cart-item{display:flex; gap:14px; padding:18px 0; border-bottom:1px solid rgba(26,26,24,0.08);}
  .cart-item img{width:78px; height:78px; object-fit:cover; border-radius:2px; background:var(--cream-dim);}
  .ci-info{flex:1; display:flex; flex-direction:column; justify-content:center; gap:5px;}
  .ci-info h4{font-size:14px; font-weight:600;}
  .ci-info .meta{font-family:'JetBrains Mono',monospace; font-size:11px; color:#7a766b;}
  .ci-row{display:flex; justify-content:space-between; align-items:center;}
  .ci-price{font-family:'JetBrains Mono',monospace; font-weight:700; font-size:13.5px;}
  .ci-remove{background:none; border:none; cursor:pointer; color:#9a958a; font-size:11px; font-family:'JetBrains Mono',monospace; text-decoration:underline;}
  .ci-remove:hover{color:var(--orange-dim);}
  .drawer-foot{padding:24px 28px 30px; border-top:1px solid rgba(26,26,24,0.1);}
  .drawer-foot .row{display:flex; justify-content:space-between; margin-bottom:18px; font-family:'JetBrains Mono',monospace; font-size:13px;}
  .drawer-foot .row.total{font-size:16px; font-weight:700;}
  .btn-block{width:100%; justify-content:center;}

  .toast{
    position:fixed; bottom:28px; left:50%; transform:translateX(-50%) translateY(20px);
    background:var(--charcoal); color:var(--cream); padding:14px 22px; border-radius:3px;
    font-size:13px; font-weight:600; display:flex; align-items:center; gap:10px;
    opacity:0; pointer-events:none; transition:all .35s cubic-bezier(.2,.7,.3,1); z-index:300;
  }
  .toast.show{opacity:1; transform:translateX(-50%) translateY(0);}
  .toast .dot2{width:8px; height:8px; border-radius:50%; background:var(--orange);}

  /* ---------- Side menu (pages) ---------- */
  .side-menu{
    position:fixed; top:0; left:0; bottom:0; width:340px; max-width:88vw;
    background:var(--charcoal); color:var(--cream); z-index:201;
    transform:translateX(-100%); transition:transform .4s cubic-bezier(.2,.7,.3,1);
    display:flex; flex-direction:column;
  }
  .side-menu.open{transform:translateX(0);}
  .side-menu-head{display:flex; justify-content:space-between; align-items:center; padding:26px 28px; border-bottom:1px solid rgba(245,242,234,0.12);}
  .side-menu-head .foot-logo{margin-bottom:0; font-size:21px;}
  .side-menu-close{background:none; border:none; cursor:pointer; width:34px; height:34px; display:flex; align-items:center; justify-content:center; color:var(--cream);}
  .side-menu-close svg{width:18px; height:18px;}
  .side-menu-list{padding:14px 10px; overflow-y:auto;}
  .side-menu-list button{
    display:flex; align-items:center; justify-content:space-between;
    width:100%; background:none; border:none; cursor:pointer; text-align:left;
    color:var(--cream); font-family:'Anton',sans-serif; text-transform:uppercase;
    font-size:19px; letter-spacing:.01em; padding:17px 18px;
    border-radius:var(--radius); transition:background .2s ease, color .2s ease, padding-left .2s ease;
  }
  .side-menu-list button:hover{background:rgba(245,242,234,0.06); color:var(--orange); padding-left:24px;}
  .side-menu-list button .mono{font-size:11px; color:var(--stone); letter-spacing:.04em;}
  .side-menu-divider{height:1px; background:rgba(245,242,234,0.1); margin:10px 18px;}

  /* ---------- Responsive ---------- */
  @media (max-width:1100px){
    .grid{grid-template-columns:repeat(2,1fr);}
    .foot-grid{grid-template-columns:1fr 1fr;}
  }
  @media (max-width:880px){
    .hero{grid-template-columns:1fr; min-height:auto; padding-top:36px;}
    .hero-art{height:340px; order:-1;}
    .hero-art img{width:340px;}
    .hero-art .ring{width:300px; height:300px;}
    .hero-art .ring2{width:230px; height:230px;}
    .ratings-strip .wrap{flex-direction:column; align-items:flex-start;}
  }
  @media (max-width:600px){
    .wrap{padding:0 20px;}
    .grid{grid-template-columns:1fr 1fr; gap:16px;}
    .section{padding:50px 0;}
    .nav{padding:16px 20px;}
    .foot-grid{grid-template-columns:1fr;}
  }
</style>
</head>
<body>

<div class="topbar">
  <div class="wrap">
    <span>Free Shipping On First Order</span>
  </div>
</div>

<header>
  <nav class="nav">
    <div class="nav-left">
      <button class="menu-toggle" id="menuToggle" aria-label="Open menu">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
      <div class="logo"><span class="dot"></span>FootStride</div>
    </div>
    <div class="navactions">
      <button class="icon-btn" aria-label="Search">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </button>
      <button class="icon-btn" id="cartBtn" aria-label="Open cart">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4"/><path d="M3 6h18"/><path d="M16 10a4 4 0 01-8 0"/></svg>
        <span class="cart-count" id="cartCount">0</span>
      </button>
    </div>
  </nav>
</header>

<section class="hero">
  <div class="hero-copy">
    <span class="hero-eyebrow">Engineered traction · Since 2019</span>
    <h1 class="display">Every<br>step,<br><span class="stroke">earned.</span></h1>
    <p>Trail-tested footwear built from the ground up — for tarmac sprints, mountain switchbacks, and everything between. No filler, just grip, comfort, and mileage.</p>
    <div class="hero-ctas">
      <a href="#shop" class="btn btn-primary">Shop the collection</a>
      <a href="#ratings" class="btn btn-ghost">See ratings</a>
    </div>
    <div class="hero-stats">
      <div><div class="num display">40K+</div><div class="label">Pairs shipped</div></div>
      <div><div class="num display">4.8/5</div><div class="label">Avg. rating</div></div>
      <div><div class="num display">30-Day</div><div class="label">Trail trial</div></div>
    </div>
  </div>
  <div class="hero-art">
    <div class="ring"></div>
    <div class="ring2"></div>
    <img src="https://images.unsplash.com/photo-1542291026-7eec264c27ff?auto=format&fit=crop&w=900&q=80" alt="FootStride Trailhead 02 running shoe">
    <div class="hero-tag"><span class="swatch"></span>Trailhead 02 — Rust Clay</div>
  </div>
</section>

<div class="marquee">
  <div class="marquee-track">
    <span>RUN <em>·</em> TRAIL <em>·</em> COURT <em>·</em> STREET <em>·</em> TRAIN <em>·</em> RUN <em>·</em> TRAIL <em>·</em> COURT <em>·</em> STREET <em>·</em> TRAIN</span>
    <span>RUN <em>·</em> TRAIL <em>·</em> COURT <em>·</em> STREET <em>·</em> TRAIN <em>·</em> RUN <em>·</em> TRAIL <em>·</em> COURT <em>·</em> STREET <em>·</em> TRAIN</span>
  </div>
</div>

<section class="section" id="shop">
  <div class="wrap">
    <div class="section-head">
      <div>
        <span class="eyebrow">The lineup</span>
        <h2 class="display">Pick your<br>terrain</h2>
      </div>
      <p>Every silhouette below ships with our cushioned StrideFoam™ midsole and a 30-day trail trial — wear them outside, return them if they don't earn a place in your rotation.</p>
    </div>

    <div class="filters" id="filters">
      <button class="chip active" data-cat="all">All</button>
      <button class="chip" data-cat="sneakers">Sneakers</button>
      <button class="chip" data-cat="boots">Boots</button>
      <button class="chip" data-cat="trail">Trail</button>
    </div>

    <div class="grid" id="grid"></div>
  </div>
</section>

<section class="ratings-strip" id="ratings">
  <div class="wrap">
    <div class="ratings-score">
      <div class="num display">4.8</div>
      <div>
        <div class="ratings-stars">★★★★★</div>
        <div class="label">2,300+ verified ratings</div>
      </div>
    </div>
    <p class="ratings-quote">"<span>300km in</span> and the tread still looks unworn — first pair that's outlasted my own stubbornness."<br>— Dana M., verified buyer</p>
  </div>
</section>

<footer id="footer">
  <div class="wrap">
    <div class="foot-grid">
      <div>
        <div class="foot-logo">FootStride</div>
        <p>Trail-tested footwear engineered for grip, comfort, and mileage — designed in Portland, tested on actual mountains.</p>
      </div>
      <div class="foot-col">
        <h5>Company</h5>
        <a href="#ratings">Ratings</a>
        <a href="#">Sustainability</a>
        <a href="#">Careers</a>
      </div>
      <div class="foot-col">
        <h5>Support</h5>
        <a href="#">Shipping &amp; returns</a>
        <a href="#">Size guide</a>
        <a href="#">Track order</a>
        <a href="#">Contact us</a>
      </div>
    </div>
    <div class="foot-bottom">
      <span>© 2026 FootStride. All rights reserved.</span>
      <span>Made for the long run.</span>
    </div>
  </div>
</footer>

<div class="overlay" id="overlay"></div>

<aside class="side-menu" id="sideMenu" aria-label="Site menu">
  <div class="side-menu-head">
    <div class="foot-logo">FootStride</div>
    <button class="side-menu-close" id="sideMenuClose" aria-label="Close menu">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>
  <div class="side-menu-list">
    <button data-action="filter" data-value="bestsellers">Best Sellers</button>
    <button data-action="filter" data-value="under999">Under ₹999</button>
    <button data-action="filter" data-value="sneakers">Sneakers</button>
    <button data-action="filter" data-value="boots">Boots</button>
    <div class="side-menu-divider"></div>
    <button data-action="scroll" data-value="footer">Contact Us</button>
    <button data-action="scroll" data-value="ratings">Ratings</button>
  </div>
</aside>

<aside class="drawer" id="drawer" aria-label="Shopping cart">
  <div class="drawer-head">
    <h3>Your bag</h3>
    <button class="drawer-close" id="drawerClose" aria-label="Close cart">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>
  <div class="drawer-body" id="drawerBody"></div>
  <div class="drawer-foot" id="drawerFoot" style="display:none;">
    <div class="row"><span>Subtotal</span><span id="subtotal">$0</span></div>
    <div class="row total"><span>Total</span><span id="total">$0</span></div>
    <button class="btn btn-primary btn-block" id="checkoutBtn">Checkout</button>
  </div>
</aside>

<div class="toast" id="toast"><span class="dot2"></span><span id="toastMsg">Added to bag</span></div>

<script>
  const products = [
    {id:1, name:"Trailhead 02", cat:"trail", price:1499, was:null, img:"https://images.unsplash.com/photo-1542291026-7eec264c27ff?auto=format&fit=crop&w=600&q=80", colors:["#c2562f","#1a1a18","#b8b2a3"], badge:"New", bestseller:true},
    {id:2, name:"Court Classic", cat:"sneakers", price:699, was:null, img:"https://images.unsplash.com/photo-1600185365483-26d7a4cc7519?auto=format&fit=crop&w=600&q=80", colors:["#f5f2ea","#1a1a18"], badge:null, bestseller:true},
    {id:3, name:"Street Low", cat:"sneakers", price:760, was:null, img:"https://images.unsplash.com/photo-1525966222134-fcfa99b8ae77?auto=format&fit=crop&w=600&q=80", colors:["#b8b2a3","#1a1a18"], badge:null, bestseller:false},
    {id:4, name:"Chukka Classic", cat:"boots", price:820, was:null, img:"https://images.unsplash.com/photo-1608256246200-53e635b5b65f?auto=format&fit=crop&w=600&q=80", colors:["#7c8a6e","#1a1a18"], badge:null, bestseller:true},
    {id:5, name:"Drift Canvas", cat:"sneakers", price:999, was:null, img:"https://images.unsplash.com/photo-1491553895911-0055eca6402d?auto=format&fit=crop&w=600&q=80", colors:["#f5f2ea","#7c8a6e","#c2562f"], badge:"New", bestseller:false},
    {id:6, name:"Velocity Air", cat:"sneakers", price:1199, was:null, img:"https://images.unsplash.com/photo-1556906781-9a412961c28c?auto=format&fit=crop&w=600&q=80", colors:["#1a1a18","#b8b2a3","#4f6b57"], badge:null, bestseller:false},
    {id:7, name:"Desert Boot", cat:"boots", price:1599, was:1799, img:"https://images.unsplash.com/photo-1605812860427-4024433a70fd?auto=format&fit=crop&w=600&q=80", colors:["#b08576","#1a1a18"], badge:"Sale", bestseller:false},
    {id:8, name:"Summit Ridge", cat:"trail", price:1799, was:1999, img:"https://images.unsplash.com/photo-1606107557195-0e29a4b5b4aa?auto=format&fit=crop&w=600&q=80", colors:["#4f6b57","#1a1a18"], badge:"Sale", bestseller:false},
  ];

  const grid = document.getElementById('grid');
  const filters = document.getElementById('filters');
  let cart = [];
  let activeFilter = 'all';

  function getFiltered(cat){
    if(cat === 'all') return products;
    if(cat === 'bestsellers') return products.filter(p => p.bestseller);
    if(cat === 'under999') return products.filter(p => p.price <= 999);
    return products.filter(p => p.cat === cat);
  }

  function renderGrid(cat){
    activeFilter = cat;
    grid.innerHTML = '';
    const items = getFiltered(cat);
    if(items.length === 0){
      grid.innerHTML = '<p style="grid-column:1/-1;color:#7a766b;font-family:\'JetBrains Mono\',monospace;font-size:13px;">No shoes found in this category.</p>';
      return;
    }
    items.forEach((p, i) => {
      const card = document.createElement('div');
      card.className = 'card';
      card.style.animationDelay = (i * 0.05) + 's';
      card.innerHTML = `
        <div class="card-media">
          ${p.badge ? `<span class="badge ${p.badge==='Sale'?'green':'sage'}">${p.badge}</span>` : ''}
          <img src="${p.img}" alt="${p.name}" loading="lazy">
          <button class="quick-add" aria-label="Add ${p.name} to bag" data-id="${p.id}">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          </button>
        </div>
        <div class="card-info">
          <span class="cat mono">${p.cat}</span>
          <h3>${p.name}</h3>
          <div class="card-foot">
            <div class="price mono">${p.was ? `<span class="was">₹${p.was}</span>` : ''}₹${p.price}</div>
            <div class="swatches">${p.colors.map(c => `<i style="background:${c}"></i>`).join('')}</div>
          </div>
        </div>`;
      grid.appendChild(card);
      requestAnimationFrame(() => card.classList.add('in-view'));
    });
    document.querySelectorAll('.quick-add').forEach(btn => {
      btn.addEventListener('click', e => {
        e.preventDefault();
        addToCart(parseInt(btn.dataset.id));
      });
    });
  }

  filters.addEventListener('click', e => {
    const chip = e.target.closest('.chip');
    if(!chip) return;
    document.querySelectorAll('.chip').forEach(c => c.classList.remove('active'));
    chip.classList.add('active');
    renderGrid(chip.dataset.cat);
  });

  renderGrid('all');

  // Side menu
  const sideMenu = document.getElementById('sideMenu');
  const menuToggle = document.getElementById('menuToggle');
  const sideMenuClose = document.getElementById('sideMenuClose');

  function openSideMenu(){ sideMenu.classList.add('open'); overlay.classList.add('open'); }
  function closeSideMenu(){ sideMenu.classList.remove('open'); overlay.classList.remove('open'); }
  menuToggle.addEventListener('click', openSideMenu);
  sideMenuClose.addEventListener('click', closeSideMenu);

  document.querySelectorAll('.side-menu-list button').forEach(btn => {
    btn.addEventListener('click', () => {
      closeSideMenu();
      const action = btn.dataset.action;
      const val = btn.dataset.value;
      if(action === 'filter'){
        document.getElementById('shop').scrollIntoView({behavior:'smooth'});
        setTimeout(() => {
          document.querySelectorAll('.chip').forEach(c => c.classList.remove('active'));
          renderGrid(val);
        }, 400);
      } else if(action === 'scroll'){
        document.getElementById(val)?.scrollIntoView({behavior:'smooth'});
      }
    });
  });

  // Cart logic
  const cartBtn = document.getElementById('cartBtn');
  const drawer = document.getElementById('drawer');
  const drawerClose = document.getElementById('drawerClose');
  const drawerBody = document.getElementById('drawerBody');
  const drawerFoot = document.getElementById('drawerFoot');
  const cartCount = document.getElementById('cartCount');
  const subtotalEl = document.getElementById('subtotal');
  const totalEl = document.getElementById('total');
  const toast = document.getElementById('toast');
  const toastMsg = document.getElementById('toastMsg');
  const overlay = document.getElementById('overlay');

  function openDrawer(){ drawer.classList.add('open'); overlay.classList.add('open'); }
  function closeDrawer(){ drawer.classList.remove('open'); overlay.classList.remove('open'); }
  cartBtn.addEventListener('click', openDrawer);
  drawerClose.addEventListener('click', closeDrawer);
  overlay.addEventListener('click', () => { closeDrawer(); closeSideMenu(); });

  function addToCart(id){
    const product = products.find(p => p.id === id);
    const existing = cart.find(c => c.id === id);
    if(existing){ existing.qty += 1; } else { cart.push({...product, qty:1}); }
    renderCart();
    showToast(`${product.name} added to bag`);
  }

  function removeFromCart(id){
    cart = cart.filter(c => c.id !== id);
    renderCart();
  }

  function renderCart(){
    const totalQty = cart.reduce((s,c) => s + c.qty, 0);
    cartCount.textContent = totalQty;
    if(cart.length === 0){
      drawerBody.innerHTML = `<div class="drawer-empty">
        <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="#b8b2a3" stroke-width="1.5"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4"/><path d="M3 6h18"/><path d="M16 10a4 4 0 01-8 0"/></svg>
        <p>Your bag is empty.<br>Find something built to last.</p>
      </div>`;
      drawerFoot.style.display = 'none';
      return;
    }
    drawerFoot.style.display = 'block';
    drawerBody.innerHTML = cart.map(c => `
      <div class="cart-item">
        <img src="${c.img}" alt="${c.name}">
        <div class="ci-info">
          <h4>${c.name}</h4>
          <span class="meta mono">QTY ${c.qty} · ${c.cat}</span>
          <div class="ci-row">
            <span class="ci-price mono">₹${c.price * c.qty}</span>
            <button class="ci-remove" data-id="${c.id}">Remove</button>
          </div>
        </div>
      </div>`).join('');
    document.querySelectorAll('.ci-remove').forEach(btn => {
      btn.addEventListener('click', () => removeFromCart(parseInt(btn.dataset.id)));
    });
    const subtotal = cart.reduce((s,c) => s + c.price * c.qty, 0);
    subtotalEl.textContent = `₹${subtotal}`;
    totalEl.textContent = `₹${subtotal}`;
  }

  function showToast(msg){
    toastMsg.textContent = msg;
    toast.classList.add('show');
    clearTimeout(window._toastTimer);
    window._toastTimer = setTimeout(() => toast.classList.remove('show'), 2400);
  }

  document.getElementById('checkoutBtn').addEventListener('click', () => {
    showToast('Checkout coming soon — bag saved');
  });


  // Reveal cards on scroll for sections beyond first paint
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if(entry.isIntersecting){
        entry.target.classList.add('in-view');
        observer.unobserve(entry.target);
      }
    });
  }, {threshold:0.1});
  document.querySelectorAll('.card').forEach(c => observer.observe(c));
</script>

</body>
</html>
